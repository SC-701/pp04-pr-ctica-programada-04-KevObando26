﻿
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Curso Vehiculos</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!-- Bootstrap Icons (opcional, pero se ve pro) -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
</head>

<body class="bg-light">

    <!-- Navbar -->
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark border-bottom shadow-sm sticky-top">
            <div class="container">
                <a class="navbar-brand fw-semibold d-flex align-items-center gap-2" asp-page="/Index">
                    <i class="bi bi-car-front-fill"></i>
                    <span>Progra Vehículos</span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMain"
                        aria-controls="navMain" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navMain">
                    <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-2">
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Index">
                                <i class="bi bi-house-door me-1"></i> Inicio
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Vehiculos/Index">
                                <i class="bi bi-list-check me-1"></i> Vehículos
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Privacy">
                                <i class="bi bi-shield-lock me-1"></i> Privacidad
                            </a>
                        </li>
                        <div class="align-content-end navbar-nav text-uppercase">
                           @await Html.PartialAsync("_AutenticacionParcial")
                        </div>

                        <!-- Botón call-to-action -->
                   
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <!-- Contenido -->
    <main class="py-4">
        <div class="container">

            <!-- Encabezado de página -->
            <div class="mb-4">
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-end gap-2">
                    <div>
                        <h1 class="h3 fw-bold mb-1">@ViewData["Title"]</h1>
                        <div class="text-muted small">
                            Curso SC-701 • Razor Pages • ASP.NET Core
                        </div>
                    </div>

                    <!-- Breadcrumb simple (opcional) -->
                    <div class="text-muted small">
                        <i class="bi bi-geo-alt"></i> @DateTime.Now.ToString("dd/MM/yyyy")
                    </div>
                </div>
            </div>

            <!-- Tarjeta contenedora -->
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    @RenderBody()
                </div>
            </div>

        </div>
    </main>

    <!-- Footer -->
    <footer class="mt-auto py-4">
        <div class="container">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center gap-2 border-top pt-3 text-muted small">
                <div>© @DateTime.Now.Year • SC-701 • Web Vehículos</div>

                <div class="d-flex gap-3">
                    <a class="text-muted text-decoration-none" asp-page="/Privacy">Privacidad</a>
                    <a class="text-muted text-decoration-none" href="https://learn.microsoft.com/aspnet/core" target="_blank" rel="noopener">Docs</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>